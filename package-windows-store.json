  },
  "appx": {
    "applicationId": "OptiRest",
    "backgroundColor": "#0a0e27",
    "displayName": "OptiRest",
    "identityName": "com.blogsaays.optirest",
    "publisher": "CN=Saurabh Mukhekar",
    "publisherDisplayName": "Saurabh Mukhekar"
  }
}
