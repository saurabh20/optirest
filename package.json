{
  "name": "optirest",
  "version": "1.0.0",
  "description": "Cross-platform eye strain prevention app — 20-20-20 rule",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "dist-mac": "electron-builder --mac",
    "dist-win": "electron-builder --win",
    "dist-linux": "electron-builder --linux"
  },
  "keywords": ["electron", "eye-health", "productivity", "20-20-20"],
  "author": "Saurabh Mukhekar",
  "homepage": "https://www.blogsaays.com",
  "license": "MIT",
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "build": {
    "appId": "com.blogsaays.optirest",
    "productName": "OptiRest",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "src/assets/icons/app-icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icons/app-icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icons/app-icon.png"
    }
  }
}
