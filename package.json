{
  "name": "optirest",
  "version": "1.0.0",
  "description": "Cross-platform eye strain prevention app — 20-20-20 rule",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "obfuscate": "node scripts/obfuscate.mjs",
    "dist-mac": "npm run obfuscate && electron-builder --mac",
    "dist-win": "electron-builder --win --config package-windows.json",
    "dist-linux": "npm run obfuscate && electron-builder --linux"
  },
  "keywords": [
    "electron",
    "eye-health",
    "productivity",
    "20-20-20"
  ],
  "author": "Saurabh Mukhekar",
  "homepage": "https://www.blogsaays.com",
  "license": "PolyForm-Noncommercial-1.0.0",
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "javascript-obfuscator": "^5.4.2",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "build": {
    "appId": "com.blogsaays.optirest",
    "productName": "OptiRest",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src-obfuscated/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src-obfuscated/main.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "src/assets/icons/app-icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icons/app-icon.ico",
      "publisherName": "Saurabh Mukhekar",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "src/assets/icons/app-icon.ico",
      "uninstallerIcon": "src/assets/icons/app-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OptiRest",
      "runAfterFinish": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icons/app-icon.png"
    }
  }
}
